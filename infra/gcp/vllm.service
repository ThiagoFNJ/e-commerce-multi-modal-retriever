[Unit]
Description=vLLM OpenAI-compatible server (gemma-4-12B, BF16)
After=network-online.target

[Service]
ExecStart=/opt/conda/bin/vllm serve google/gemma-4-12B \
  --dtype bfloat16 \
  --max-model-len 4096 \
  --gpu-memory-utilization 0.92 \
  --disable-log-requests \
  --port 8000
Restart=always
RestartSec=10
Environment=HF_HUB_OFFLINE=0

[Install]
WantedBy=multi-user.target
